{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
   "Cratis": {
        "Arc": {
            "GeneratedApis": {
                "RoutePrefix": "api",
                "IncludeCommandNameInRoute": false,
                "SegmentsToSkipForRoute": 1
            }
        },
        "MongoDB": {
            "Server": "mongodb://localhost:27017",
            "Database": "arc-testapp"
        }
    }
}
