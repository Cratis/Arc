<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <AssemblyName>Cratis.Arc.MongoDB</AssemblyName>
        <RootNamespace>Cratis.Arc.MongoDB</RootNamespace>
        <!-- CS0436: OneOf.SourceGenerator generates GenerateOneOfAttribute here, but it is also compiled
             into Cratis.Arc.Core (via Cratis.Fundamentals). Suppress the false-positive type conflict. -->
        <NoWarn>$(NoWarn);CS0436</NoWarn>
    </PropertyGroup>
    <ItemGroup>
        <FrameworkReference Include="Microsoft.AspNetCore.App" />
        <InternalsVisibleTo Include="Cratis.Arc.MongoDB.Specs" />
    </ItemGroup>
    <ItemGroup>
        <PackageReference Include="Cratis.Fundamentals" />
        <PackageReference Include="Cratis.Metrics.Roslyn" />
        <PackageReference Include="Microsoft.Extensions.Resilience" />
        <PackageReference Include="castle.core" />
        <PackageReference Include="MongoDB.Driver" />
        <PackageReference Include="Microsoft.Extensions.Logging" />
        <PackageReference Include="Microsoft.Extensions.Hosting" />
        <PackageReference Include="Snappier" />
        <PackageReference Include="SharpCompress" />
    </ItemGroup>
    <ItemGroup>
        <ProjectReference Include="../Arc.Core/Arc.Core.csproj" />
    </ItemGroup>
</Project>
