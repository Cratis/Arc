<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <OutputType>Exe</OutputType>
        <AssemblyName>Cratis.Arc.ProxyGenerator</AssemblyName>
        <RootNamespace>Cratis.Arc.ProxyGenerator</RootNamespace>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <PackAsTool>true</PackAsTool>
        <ToolCommandName>proxygenerator</ToolCommandName>
        <NoWarn>$(NoWarn);IL2026;IL3000;IL3002;IL2067;IL2070;IL2072;IL2075</NoWarn>
    </PropertyGroup>

    <ItemGroup>
        <EmbeddedResource Include="$(MSBuildThisFileDirectory)/Templates/**/*.hbs" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="handlebars.net" />
        <PackageReference Include="Microsoft.Extensions.DependencyModel" />
        <PackageReference Include="System.Reflection.MetadataLoadContext" />
    </ItemGroup>
</Project>
